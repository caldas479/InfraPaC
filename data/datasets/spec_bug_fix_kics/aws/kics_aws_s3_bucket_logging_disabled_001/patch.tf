provider "aws" { region = "us-east-1" } resource "aws_s3_bucket" "my-tf-test-bucket" { bucket = "my-tf-test-bucket" acl = "private" tags = { Name = "My bucket", Environment = "Dev" } versioning { mfa_delete = true } logging { target_bucket = aws_s3_bucket.log-bucket } } resource "aws_s3_bucket" "log-bucket" { bucket = "my-tf-test-bucket-logs" acl = "private" tags = { Name = "My logs", Environment = "Dev" } versioning { mfa_delete = true } logging { target_bucket = aws_s3_bucket.log-bucket } }
